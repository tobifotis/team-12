<!DOCTYPE html>
<html lang="en">
  <%- include('includes/head2') %>
  <link rel="stylesheet" href="/profile.css" />
  <body>
    <%- include('includes/header') %>

    <main class="profile-page">
      <section class="profile-card">

        <div class="profile-content">
          <div class="profile-header-section">
            <div class="profile-image-block">
              <img
                id="profilePicturePreview"
                src=""
                alt="Profile picture"
                class="profile-picture"
              />
            </div>

            <div class="profile-title-block">
              <h1 id="displayNameText" class="display-name">Display Name</h1>
              <p id="currentRoleText" class="current-role icon-line">
                <img src="/images/briefcase.svg" class="icon-img" alt="Briefcase icon" />
                <span id="currentRoleValue">Current Role</span>
              </p>
              <p id="organizationText" class="organization icon-line">
                <img src="/images/location.svg" class="icon-img" alt="Location icon" />
                <span id="organizationValue">Organization</span>
              </p>
            </div>
          </div>

          <div class="bio-section">
            <div id="bioView" class="bio-box">
              <h3>Short Bio</h3>
              <p id="bioViewText" class="bio-text"></p>
            </div>
          </div>

          <div class="profile-grid">
            <div class="profile-section">
              <h3>Skills</h3>
              <div id="skillsList" class="skill-pills view-mode"></div>
            </div>

            <div class="profile-section">
              <h3>Availability</h3>
              <div id="availabilityList" class="availability-list"></div>
            </div>
          </div>

          <div class="profile-actions">
            <button type="button" id="editProfileBtn" class="edit-btn">Edit Profile</button>
          </div>

          <p id="profileStatus" class="status-text"></p>
        </div>
      </section>
    </main>

    <script src="/js/profile-page.js"></script>
  </body>
</html>
