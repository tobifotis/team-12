<!DOCTYPE html>
<html lang="en">
<%- include('includes/head') %>

<body class="workspace-page">
<%- include('includes/header') %>

<main class="workspace-layout">

  <!-- LEFT PANEL -->
  <section class="workspace-left">
    <h2>Your Workspaces</h2>

    <% if (workspaces.length === 0) { %>
      <p>No workspaces yet.</p>
    <% } %>

    <% workspaces.forEach(workspace => { %>
      <div class="workspace-card">
        <div class="workspace-title"><%= workspace.workspaceName %></div>
        <div class="workspace-code">Code: <%= workspace.joinCode %></div>
      </div>
    <% }) %>
  </section>

  <!-- RIGHT PANEL -->
  <section class="workspace-right">
    <div class="workspace-right-inner">

      <h2>Enter a New Workspace</h2>

      <div class="workspace-entry-buttons">
        <a href="/workspaces/create" class="btn-yellow">Create Workspace</a>
        <span class="or-text">Or</span>
        <a href="/workspaces/join-page" class="btn-dark">Join Workspace</a>
      </div>

    </div>
  </section>

</main>

</body>
</html>